RESEND_API_KEY=re_your_api_key_here
JWT_SECRET=your_jwt_secret_here
PORT=3000
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key
SUPABASE_STORAGE_REQUIRED=true
SUPABASE_STORAGE_PROBE_ON_STARTUP=true
SUPABASE_AUTH_HOOK_SECRET=whsec_your_supabase_auth_hook_secret
GOOGLE_MAPS_API_KEY=your_google_maps_key
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GEMINI_API_KEY=your_gemini_api_key

# iSMS auth SMS delivery for Supabase Send SMS Hook
ISMS_USERNAME=your_isms_username
ISMS_PASSWORD=your_isms_password
ISMS_SENDER_ID=CarryOn
ISMS_SMS_ENDPOINTS=https://smtpapi2.vocotext.com/isms_send_all_id.php,https://ww3.isms.com.my/isms_send_all_id.php,https://smtpapi.vocotext.com/isms_send_all_id.php
ISMS_SMS_TIMEOUT_MS=1500
AUTH_SMS_OTP_TEMPLATE=Your CarryOn verification code is {{otp}}.

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CURRENCY=myr
STRIPE_COUNTRY=MY
STRIPE_CONNECT_COUNTRY=MY
STRIPE_CONNECT_RETURN_URL=carryon-driver://stripe-connect/return
STRIPE_CONNECT_REFRESH_URL=carryon-driver://stripe-connect/refresh
WALLET_TOPUP_MIN=10
WALLET_TOPUP_MAX=1000
DRIVER_COMMISSION_RATE=0.88

# Admin dashboard authentication
ADMIN_API_KEY=asdnaskdnajks

# CORS — comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3001
